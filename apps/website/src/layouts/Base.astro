---
// DAY-166. Base page layout.
//
// Responsibilities:
//   - HTML shell, character set, viewport.
//   - Brand-aware favicon + SVG source of truth.
//   - Inter / JetBrains Mono via @fontsource CDN-free fallbacks.
//   - Open Graph + Twitter Card meta (per page — title/description
//     props make the layout reusable for future /privacy, /changelog,
//     etc. subpages).
//   - The global.css that sets the charcoal default background and
//     the reduced-motion gate used by every other component.
//
// Intentionally NOT included here: analytics/telemetry scripts.
// The site ships zero tracking; the "no telemetry" trust bullet on
// the landing would be a lie if this layout quietly loaded GA.
import "../styles/global.css";
import SiteNav from "../components/SiteNav.astro";
import SiteFooter from "../components/SiteFooter.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Dayseam, the report of your day, written from evidence",
  description = "Dayseam is a local first work reporting app that stitches evidence from GitHub, GitLab, Jira, Confluence, and your local repos into an editable daily report, and saves it to Markdown or your Obsidian vault. Free, no account, no telemetry",
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? "https://dayseam.github.io").toString();
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <link rel="icon" type="image/svg+xml" href="/dayseam-mark.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Dayseam" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <meta name="theme-color" content="#17171A" />
  </head>
  <body class="min-h-screen bg-charcoal-800 text-zinc-100 font-sans antialiased">
    <SiteNav />
    <main id="main">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
