exports[`App visual shape > renders the dark-theme DOM shape 1`] = `"<div class="flex min-h-screen flex-col bg-white text-neutral-900 dark:bg-neutral-950 dark:text-neutral-100"><header class="flex items-center justify-between border-b border-neutral-200 px-6 py-4 dark:border-neutral-800"><div class="flex flex-col gap-0.5"><h1 class="text-xl font-semibold tracking-tight text-neutral-900 dark:text-neutral-50">Dayseam</h1><p class="text-xs text-neutral-500 dark:text-neutral-400">Local-first automated work reporting — early scaffold</p></div><div role="radiogroup" aria-label="Theme" class="inline-flex rounded-md border border-neutral-300 p-0.5 text-xs dark:border-neutral-700"><button type="button" role="radio" aria-checked="false" title="Force light theme" class="rounded px-2.5 py-1 transition text-neutral-600 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-neutral-100">Light</button><button type="button" role="radio" aria-checked="false" title="Follow the operating-system appearance" class="rounded px-2.5 py-1 transition text-neutral-600 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-neutral-100">System</button><button type="button" role="radio" aria-checked="true" title="Force dark theme" class="rounded px-2.5 py-1 transition bg-neutral-900 text-white dark:bg-neutral-100 dark:text-neutral-900">Dark</button></div></header><section aria-label="Report actions" class="flex flex-wrap items-center gap-3 border-b border-neutral-200 bg-neutral-50/50 px-6 py-3 dark:border-neutral-800 dark:bg-neutral-900/40"><label class="flex items-center gap-2 text-sm text-neutral-700 dark:text-neutral-200"><span>Date</span><input type="date" aria-label="Report date" data-testid="action-row-date" class="rounded border border-neutral-300 bg-white px-2 py-1 text-sm text-neutral-800 disabled:cursor-not-allowed disabled:opacity-60 dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-200" value="2026-04-19"></label><fieldset class="flex flex-wrap items-center gap-1" aria-label="Sources included in the report"><span class="text-xs text-neutral-500 dark:text-neutral-400">Add a source above to enable Generate.</span></fieldset><button type="button" disabled="" data-testid="action-row-generate" class="ml-auto rounded bg-neutral-900 px-3 py-1.5 text-sm font-medium text-white disabled:cursor-not-allowed disabled:opacity-50 dark:bg-neutral-100 dark:text-neutral-900">Generate report</button></section><section aria-label="Connected sources" class="flex flex-wrap items-center gap-2 border-b border-neutral-200 px-6 py-3 dark:border-neutral-800"><span class="text-xs uppercase tracking-wide text-neutral-500 dark:text-neutral-400">Sources</span><span class="text-xs text-neutral-400 dark:text-neutral-500">No sources connected</span><button type="button" class="ml-auto rounded border border-neutral-300 px-2 py-0.5 text-xs text-neutral-700 hover:bg-neutral-50 dark:border-neutral-700 dark:text-neutral-200 dark:hover:bg-neutral-900">Add local git source</button></section><section aria-label="Report preview" class="flex flex-1 flex-col items-center justify-center gap-2 px-6 py-10 text-center"><div aria-hidden="true" class="h-10 w-10 rounded-full border-2 border-dashed border-neutral-300 dark:border-neutral-700"></div><h2 class="text-base font-medium text-neutral-700 dark:text-neutral-200">No report yet</h2><p class="max-w-sm text-sm text-neutral-500 dark:text-neutral-400">Pick a date, choose your sources, and hit Generate. The draft and its evidence will stream in here as it's produced.</p></section><footer aria-label="Status" class="flex items-center justify-between border-t border-neutral-200 px-6 py-2 text-xs text-neutral-500 dark:border-neutral-800 dark:text-neutral-400"><div class="flex items-center gap-3"><span>Idle</span><button type="button" title="Open activity log (⌘L)" class="rounded px-2 py-0.5 text-xs text-neutral-600 hover:bg-neutral-100 dark:text-neutral-300 dark:hover:bg-neutral-900">Logs</button><button type="button" title="Manage identity mappings" class="rounded px-2 py-0.5 text-xs text-neutral-600 hover:bg-neutral-100 dark:text-neutral-300 dark:hover:bg-neutral-900">Identities</button><button type="button" title="Manage sinks" class="rounded px-2 py-0.5 text-xs text-neutral-600 hover:bg-neutral-100 dark:text-neutral-300 dark:hover:bg-neutral-900">Sinks</button></div><span>Local-only · No data leaves this machine</span></footer></div>"`;

