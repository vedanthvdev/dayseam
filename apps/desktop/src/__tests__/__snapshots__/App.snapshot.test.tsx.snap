// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`App visual shape > renders the dark-theme DOM shape 1`] = `"<div class="flex min-h-screen flex-col bg-white text-neutral-900 dark:bg-neutral-950 dark:text-neutral-100"><header class="flex items-center justify-between border-b border-neutral-200 px-6 py-4 dark:border-neutral-800"><div class="flex flex-col gap-0.5"><h1 class="text-xl font-semibold tracking-tight text-neutral-900 dark:text-neutral-50">Dayseam</h1><p class="text-xs text-neutral-500 dark:text-neutral-400">Local-first automated work reporting — early scaffold</p></div><div role="radiogroup" aria-label="Theme" class="inline-flex rounded-md border border-neutral-300 p-0.5 text-xs dark:border-neutral-700"><button type="button" role="radio" aria-checked="false" title="Force light theme" class="rounded px-2.5 py-1 transition text-neutral-600 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-neutral-100">Light</button><button type="button" role="radio" aria-checked="false" title="Follow the operating-system appearance" class="rounded px-2.5 py-1 transition text-neutral-600 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-neutral-100">System</button><button type="button" role="radio" aria-checked="true" title="Force dark theme" class="rounded px-2.5 py-1 transition bg-neutral-900 text-white dark:bg-neutral-100 dark:text-neutral-900">Dark</button></div></header><section aria-label="Report actions" class="flex flex-wrap items-center gap-3 border-b border-neutral-200 bg-neutral-50/50 px-6 py-3 dark:border-neutral-800 dark:bg-neutral-900/40"><label class="flex items-center gap-2 text-sm text-neutral-700 dark:text-neutral-200"><span>Date</span><input type="date" disabled="" aria-disabled="true" title="Available once sources are connected (Phase 2)." class="rounded border border-neutral-300 bg-white px-2 py-1 text-sm text-neutral-500 disabled:cursor-not-allowed disabled:opacity-60 dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-400"></label><button type="button" disabled="" aria-disabled="true" title="Available once sources are connected (Phase 2)." class="ml-auto rounded bg-neutral-900 px-3 py-1.5 text-sm font-medium text-white disabled:cursor-not-allowed disabled:opacity-50 dark:bg-neutral-100 dark:text-neutral-900">Generate report</button></section><section aria-label="Connected sources" class="flex flex-wrap items-center gap-2 border-b border-neutral-200 px-6 py-3 dark:border-neutral-800"><span class="text-xs uppercase tracking-wide text-neutral-500 dark:text-neutral-400">Sources</span><span title="Connect flow lands in Phase 2." class="inline-flex items-center gap-1.5 rounded border border-dashed border-neutral-300 px-2 py-0.5 text-xs text-neutral-500 dark:border-neutral-700 dark:text-neutral-400"><span aria-hidden="true" class="h-1.5 w-1.5 rounded-full bg-neutral-300 dark:bg-neutral-600"></span>Local git<span class="sr-only"> — not connected</span></span><span title="Connect flow lands in Phase 2." class="inline-flex items-center gap-1.5 rounded border border-dashed border-neutral-300 px-2 py-0.5 text-xs text-neutral-500 dark:border-neutral-700 dark:text-neutral-400"><span aria-hidden="true" class="h-1.5 w-1.5 rounded-full bg-neutral-300 dark:bg-neutral-600"></span>GitLab<span class="sr-only"> — not connected</span></span><span class="ml-auto text-xs text-neutral-400 dark:text-neutral-500">No sources connected</span></section><section aria-label="Report preview" class="flex flex-1 flex-col items-center justify-center gap-2 px-6 py-10 text-center"><div aria-hidden="true" class="h-10 w-10 rounded-full border-2 border-dashed border-neutral-300 dark:border-neutral-700"></div><h2 class="text-base font-medium text-neutral-700 dark:text-neutral-200">No report yet</h2><p class="max-w-sm text-sm text-neutral-500 dark:text-neutral-400">Connect a source and pick a date in Phase 2 to generate your first draft. The preview, evidence, and export actions all live here.</p></section><footer aria-label="Status" class="flex items-center justify-between border-t border-neutral-200 px-6 py-2 text-xs text-neutral-500 dark:border-neutral-800 dark:text-neutral-400"><span>Idle</span><span>Local-only · No data leaves this machine</span></footer></div>"`;

