# --- Rust / Cargo ---
target/
**/*.rs.bk
*.pdb
# Cargo.lock is intentionally committed at the workspace root for the
# Tauri binary crate; individual library crates do not need their own.

# --- Node / pnpm / npm / yarn ---
node_modules/
.pnpm-store/
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.yarn-integrity

# --- Build outputs ---
dist/
build/
out/
.next/
.nuxt/
.turbo/
.vite/
.cache/

# --- Test / coverage ---
coverage/
*.lcov
.nyc_output/
playwright-report/
test-results/
# Playwright output dirs under the root `e2e/` workspace package
# (configured in `e2e/playwright.config.ts`). Reports are regenerated
# on every run and uploaded as a CI artifact on failure.
/e2e/report/
/e2e/test-results/
# `playwright-bdd`'s `bddgen` compiles every `.feature` into a runnable
# `.spec.ts` here before Playwright picks them up. Fully regenerated
# each run — committing the artefacts would cause drift against the
# hand-written `.feature` and step files.
/e2e/.features-gen/

# --- Tauri bundle output ---
**/src-tauri/target/
**/src-tauri/gen/schemas/
# `tauri-build`'s `AppManifest::commands` regenerates these TOML files on
# every build; they mirror the command list in `build.rs` and add no
# information a reviewer can't get from that file.
**/src-tauri/permissions/autogenerated/
# `capabilities/dev.json` is written by `build.rs` when the `dev-commands`
# feature is enabled. Keeping it out of git guarantees release bundles
# (built without the feature) cannot accidentally ship a stale dev grant.
**/src-tauri/capabilities/dev.json

# --- TypeScript incremental ---
*.tsbuildinfo
.eslintcache

# --- Env / secrets ---
.env
.env.*
!.env.example

# --- macOS ---
.DS_Store
.AppleDouble
.LSOverride
# The legacy Finder custom-icon file is literally "Icon\r"; matching it
# safely without also catching directories like "icons/" is awkward, so
# we skip it. Modern macOS does not generate this file.
._*

# --- Editors / IDEs ---
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo
*~
.nova/

# --- Logs ---
*.log
logs/

# --- Misc ---
Thumbs.db
ehthumbs.db
