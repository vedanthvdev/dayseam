---
source: crates/dayseam-core/src/error_codes.rs
expression: ALL
---
- gitlab.auth.invalid_token
- gitlab.auth.missing_scope
- gitlab.url.dns
- gitlab.url.tls
- gitlab.rate_limited
- gitlab.upstream_5xx
- gitlab.upstream_shape_changed
- local_git.repo_locked
- local_git.repo_unreadable
- sink.fs.not_writable
- sink.fs.destination_missing
- sink.malformed_marker
- run.cancelled.by_user
- run.cancelled.by_shutdown
- run.cancelled.by_superseded
- connector.unsupported.sync_request
- http.retry.budget_exhausted
- http.transport
- orchestrator.run.superseded
- orchestrator.run.cancelled
- internal.process_restarted
- db.schema.migration_failed
